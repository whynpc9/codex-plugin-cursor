{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node ${CURSOR_PLUGIN_ROOT}/scripts/session-lifecycle-hook.mjs sessionStart",
        "timeout": 5
      }
    ],
    "sessionEnd": [
      {
        "command": "node ${CURSOR_PLUGIN_ROOT}/scripts/session-lifecycle-hook.mjs sessionEnd",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "node ${CURSOR_PLUGIN_ROOT}/scripts/stop-review-gate-hook.mjs",
        "timeout": 900,
        "loop_limit": 1
      }
    ]
  }
}
